# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (MXroute)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App session signing secret (make this long/random)
SESSION_SECRET=

# Encryption key for Step 3 credential storage.
# Use a long random value. You can also use a 64-char hex key.
CREDENTIALS_ENCRYPTION_KEY=

# Admin panel credentials (single global admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional dedicated secret for admin cookie signing.
# Falls back to SESSION_SECRET if omitted.
ADMIN_SESSION_SECRET=
